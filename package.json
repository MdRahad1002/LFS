{
  "name": "last-flag-standing",
  "version": "1.1.0",
  "description": "Real-time elimination lottery game — Last Flag Standing",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:setup": "psql $DATABASE_URL -f db/schema.sql",
    "contracts:compile": "npx hardhat compile",
    "contracts:deploy:sepolia": "npx hardhat run scripts/deploy.js --network sepolia",
    "contracts:deploy:mainnet": "npx hardhat run scripts/deploy.js --network mainnet",
    "vapid:keys": "npx web-push generate-vapid-keys"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.6.1",
    "uuid": "^9.0.0",

    "dotenv": "^16.4.5",
    "cors": "^2.8.5",
    "cookie-parser": "^1.4.6",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.3.1",

    "pg": "^8.12.0",

    "jsonwebtoken": "^9.0.2",
    "ethers": "^6.12.1",

    "axios": "^1.7.2",

    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "hardhat": "^2.22.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
